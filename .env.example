APP_NAME=NoteSmith
DEBUG=false

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma4:12b
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenRouter (https://openrouter.ai/keys)
# Provides access to many models: gpt-4o, claude-sonnet-4, gemini-2.5-flash, etc.
# Falls back to Ollama if not set or if the API call fails.
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=openai/gpt-oss-120b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

CHROMA_PERSIST_DIR=./data/chroma
UPLOAD_DIR=./data/uploads

CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
# Required for the Study Loop history tables.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres URL from Supabase -> Settings -> Database -> Connection string -> URI
# Required to auto-create the history tables on backend startup.
SUPABASE_DB_URL=
